{
  "name": "playwright_mcp",
  "version": "1.0.0",
  "main": "dist/app.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/app.ts",
    "proxy:dev": "ts-node-dev --respawn --transpile-only src/proxy/mcpStdioHttpProxy.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/app.js",
    "proxy": "node dist/proxy/mcpStdioHttpProxy.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "smoke": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\examples\\smoke-test.ps1"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "Koa + TypeScript + Playwright MCP server",
  "dependencies": {
    "@koa/router": "^15.3.1",
    "koa": "^3.1.2",
    "koa-bodyparser": "^4.4.1",
    "playwright": "^1.58.2",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/koa": "^3.0.1",
    "@types/koa__router": "^12.0.5",
    "@types/koa-bodyparser": "^4.3.13",
    "@types/node": "^25.3.3",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3"
  }
}
